# LLM Provider Configuration
# Copy this file to .env and fill in your credentials.

# ── Provider Selection ─────────────────────────────────
# Options: "google_cloud" (used in the paper) or "openrouter"
LLM_PROVIDER=google_cloud

# ── Google Cloud / Vertex AI ───────────────────────────
# Used in the paper. Requires a GCP project with Vertex AI enabled.
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your-service-account.json
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_MODEL=gemini-3.1-pro-preview

# ── OpenRouter (alternative) ──────────────────────────
# OPENROUTER_API_KEY=your-api-key
# OPENROUTER_MODEL=google/gemini-3.1-pro-preview

# ── LLM Parameters (paper defaults) ──────────────────
# LLM_TEMPERATURE=0.0
# LLM_TOP_P=0.95
